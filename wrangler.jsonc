{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nagya-dashboard",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "dev": {
    "port": 3005
  },

  "vars": {
    "NAGYA_API_BASE": "https://api.nagya.app",
    "SENDER_EMAIL": "onboarding@resend.dev",
    "SENDER_NAME": "ALDI ajanlatok",
    // Resend test-mode override: with an unverified domain, emails can only be
    // delivered to the Resend account owner's address. When set, the send route
    // routes every email to this address instead of the real user email.
    "TEST_INBOX": "bator.turny@gmail.com",
    "OPENROUTER_MODEL": "google/gemini-2.0-flash-001",
    "WEATHER_LAT": "47.4979",
    "WEATHER_LON": "19.0402"
  },

  // KV namespaces on the BILDR HUB account.
  "kv_namespaces": [
    { "binding": "TAGS", "id": "c5cde28ea9754f44a06228b07ba3a7ff" },
    { "binding": "CAMPAIGNS", "id": "5f86c4db049c4c1d83c4067c05a543b5" }
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
