{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nagya-dashboard",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "vars": {
    "NAGYA_API_BASE": "https://api.nagya.app",
    "SENDER_EMAIL": "noreply@bildr.hu",
    "SENDER_NAME": "nagya.app ajanlatok",
    "OPENROUTER_MODEL": "google/gemini-2.0-flash-001",
    "WEATHER_LAT": "47.4979",
    "WEATHER_LON": "19.0402"
  },

  // KV namespaces on the BILDR HUB account.
  "kv_namespaces": [
    { "binding": "TAGS", "id": "c5cde28ea9754f44a06228b07ba3a7ff" },
    { "binding": "CAMPAIGNS", "id": "5f86c4db049c4c1d83c4067c05a543b5" }
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
